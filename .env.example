# ============================================
# WeatherAI API Configuration
# ============================================
# get your API key from https://weather-ai.co/dashboard
WEATHER_AI_API_KEY=your_weather_api_key_here
WEATHER_AI_URL=https://api.weather-ai.co/v1

# ============================================
# Application Configuration
# ============================================
APP_NAME=WeatherAI Integration
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# CORS Configuration
# ============================================
# List of origins authorized (separated by commas)
# Example: http://localhost:3000,https://monapp.com
CORS_ORIGINS=*

# ============================================
# Logging Configuration
# ============================================
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO